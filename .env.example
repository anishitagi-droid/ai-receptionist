# ─── Twilio ────────────────────────────────────────────────────────────────────
# From: console.twilio.com → Account Info (top-left)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# ─── Anthropic ─────────────────────────────────────────────────────────────────
# From: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Supabase ──────────────────────────────────────────────────────────────────
# From: app.supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App URL ───────────────────────────────────────────────────────────────────
# The public URL your server is reachable at. Used to build the absolute callback
# URL inside the TwiML <Dial> action — Twilio REQUIRES a full https:// URL here.
# A relative path like /voice/no-answer silently fails and breaks missed-call detection.
#
# Local dev:   leave blank — the server falls back to req.headers.host automatically
# Production:  set to your Railway/Render URL, e.g. https://ai-receptionist.up.railway.app
APP_URL=

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# "development" skips Twilio signature validation so you can test locally with curl.
# ALWAYS set to "production" on Railway/Render.
NODE_ENV=development
